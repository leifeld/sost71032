\section{Model degeneracy}

\begin{frame}
	\frametitle{Model degeneracy}
	\begin{itemize}
		\item Many statistics are inherently correlated.
		\item For example, closed triangles and edges.
		\item Increasing one of them leads to a decrease of the parameter of the other one to get the same network.
		\item In these situations, the MCMC sampler cannot decide in which of the two directions to move.
		\item It will finally shift all the probability mass on one of the two statistics.
		\item But this leads to a poor model.
		\item Therefore the estimation procedure cannot continue because it never gets really close to a good solution.
		\item This estimation problem affects \emph{many} models!
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{Degeneracy: illustration}
	\framesubtitle{\citep[65]{lusher2013exponential}}
	\begin{center}
		\includegraphics[width=1.0\textheight]{gof_degeneracy}
	\end{center}
\end{frame}

\begin{frame}
	\frametitle{Degeneracy: illustration}
	\framesubtitle{\citep[6]{handcock2008statnet}}
	\begin{center}
		\includegraphics[height=0.84\textheight]{gof_handcock2008}
	\end{center}
\end{frame}

\begin{frame}
	\frametitle{Degeneracy as a blessing in disguise}
	\begin{itemize}
		\item Degeneracy usually reveals poor theory!
		\item If the statistics are multicollinear, choose a better model!
		\item Blessing in disguise because estimation failure guards us against estimating a theoretically ill-specified model.
		\item Only (relatively) well-fitting models can actually be estimated.
		\item But check MCMC diagnostics (e.\,g., correlation between statistics; autocorrelation).
	\end{itemize}
\end{frame}

\begin{frame}{ERGM specification and GOF assessment as an iterative process}
	\begin{enumerate}
		\item To model networks, we first think about theoretical mechanisms that could plausibly create the network structure.
		\item Then we translate the mechanisms into measurable configurations (``network statistics'').
		\item We also find additional configurations through exploratory network analysis.
		\item We plug the configurations together, step by step, and estimate parameters/coefficients for them.
		\item Iterative re-specification to optimise GOF and avoid degeneracy. Start from a simple model and increase complexity to find out which combinations of model terms cause degeneracy.
	\end{enumerate}
\end{frame}

