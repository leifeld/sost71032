\section{The exponential random graph model: a generative probability model}

\begin{frame}
	\frametitle{Some useful concepts for inferential network modelling}
	\begin{itemize}
		\item Topology; structure.
		\item Exogenous covariate; attribute; exogenous relation.
		\item Endogeneity; endogenous process; network statistic.
		\item Data-generating process (DGP).
		\item Observation.
		\item Deterministic vs.\ stochastic processes.
		\item Local interaction.
		\item Emergence.
		\item Parametric model.
		\item Estimation.
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{ERGM theory: properties of networks}
	\begin{block}{\citet[10]{lusher2013exponential}}
		\begin{itemize}
			\item Social networks are locally emergent.
			\item Network ties not only self-organize (i.\,e., there are dependencies between ties), but they are also influenced by actor attributes and other exogenous factors.
			\item The patterns within networks can be seen as evidence for ongoing structural processes.
			\item Multiple processes can operate simultaneously.
			\item Social networks are structured, yet stochastic.
		\end{itemize}
	\end{block}
\end{frame}

\begin{frame}
	\frametitle{The exponential random graph model}
	\begin{equation*}
		\alert<2>{P(N, \boldsymbol{\theta})} = \alert<7>{\frac{\alert<5>{\exp\{\alert<4>{\boldsymbol{\theta}}^\top \alert<3,8>{\mathbf{h}(N)} \}}}{\alert<6>{\sum_{N^* \in \mathcal{N}} \exp\{\boldsymbol{\theta}^\top \mathbf{h}(N^*)\}}}}
	\end{equation*}
	\begin{itemize}
		\only<1>{\item Probability density function of the cross-sectional ERGM.}
		\only<2>{\item \alert{Probability that we observe this particular network.}}
		\only<3>{\item \alert{$\mathbf{h}(N)$ are \emph{network statistics}.}}
		\only<4>{\item \alert{Coefficients (to be estimated).}}
		\only<5>{\item \alert{Exponential function of the sum of the weighted statistics.}}
		\only<6>{\item \alert{The sum of the same for all possible topologies.}}
		\only<7>{\item \alert{Probability of a given network over all networks one could have observed.}}
		\only<8>{\item \alert{Task: define $\mathbf{h}(N)$ in order to operationalize theory.}}
	\end{itemize}
\end{frame}

\section{Model specification}

\begin{frame}
	\frametitle{Number of edges}
	\[
	h_{\text{edges}} = \sum_{i \neq j} N_{ij}
	\]
	\bigskip
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (i1) {$i$};
			\node[knoten, right=of i1] (j1) {$j$};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	Captures the baseline probability of being connected.
	
	\bigskip
	
	Causes the density of the network.
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{Edge} or \texttt{Arc}.
\end{frame}

\begin{frame}
	\frametitle{Dyadic covariate}
	\[
	h_{\text{edgecov}} = \sum_{i \neq j} N_{ij} X_{ij}
	\]
	\bigskip
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (i1) {$i$};
			\node[knoten, right=of i1] (j1) {$j$};
			\draw[->, bamberg3, line width=0.5mm] (i1.25) -- (j1.155);
			\draw[->, bamberg3, line width=0.5mm, black] (i1.335) -- (j1.205);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	This configuration captures clustering of multiple network relations in dyads.
	
	\bigskip
	
	Example: Does marriage in the Florentine families network create business relations?
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{Dyadic Attribute} $\rightarrow$ \texttt{Edge covariate}.
\end{frame}

\begin{frame}
	\frametitle{Covariates for sender and receiver}
	\[
	h_{\text{nodeocov}} = \sum_{i \neq j} N_{ij} x_{i}
	\]
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten, draw=black] (i1) {$i$};
			\node[knoten, right=of i1] (j1) {$j$};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
		\end{tikzpicture}
	\end{center}
	
	\medskip
	
	\[
	h_{\text{nodeicov}} = \sum_{i \neq j} N_{ij} x_{j}
	\]
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (i1) {$i$};
			\node[knoten, draw=black, right=of i1] (j1) {$j$};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	This term captures the effect of sender or receiver attributes.
	
	\bigskip
	
	Example: Do narcissists befriend more people? Are they befriended more often?
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{Actor-specific effects} $\rightarrow$ \texttt{Sender attribute} or \texttt{receiver attribute}.
\end{frame}

\begin{frame}
	\frametitle{Reciprocity}
	\[
	h_\text{mutual} = \sum_{i \neq j} N_{ij}N_{ji}
	\]
	\bigskip
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (i1) {$i$};
			\node[knoten, right=of i1] (j1) {$j$};
			\draw[->, bamberg3, line width=0.5mm] (i1.25) -- (j1.155);
			\draw[->, bamberg3, line width=0.5mm] (j1.205) -- (i1.335);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	Are ties in the network often reciprocated?
	
	\bigskip
	
	Example: Do email recipients often send emails back to the sender?
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{Reciprocity}.
\end{frame}

\begin{frame}
	\frametitle{Two-stars and three-stars}
	\begin{center}
		\[
		h_{\text{in-two-star}} = \sum_{i, j, k} N_{ji} N_{ki} (1 - N_{jk}) (1 - N_{kj})
		\]
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			
			% in-two-star
			\node[knoten] (i1) {$i$};
			\node[knoten, below left=of i1] (j1) {$j$};
			\node[knoten, below right=of i1] (k1) {$k$};
			\draw[->, bamberg3, line width=0.5mm] (j1) -- (i1);
			\draw[->, bamberg3, line width=0.5mm] (k1) -- (i1);
			\node[above=1mm of i1] {Incoming 2-star};
			
			% out-two-star
			\node[knoten, right=of k1] (j2) {$j$};
			\node[knoten, above right=of j2] (i2) {$i$};
			\node[knoten, below right=of i2] (k2) {$k$};
			\draw[->, bamberg3, line width=0.5mm] (i2) -- (j2);
			\draw[->, bamberg3, line width=0.5mm] (i2) -- (k2);
			\node[above=1mm of i2] {Outgoing 2-star};
			
			% out-three-star
			\node[knoten, right=of k2] (j3) {$j$};
			\node[knoten, above right=of j3] (i3) {$i$};
			\node[knoten, below right=of i3] (l3) {$l$};
			\node[knoten, below=of i3] (k3) {$k$};
			\draw[->, bamberg3, line width=0.5mm] (i3) -- (j3);
			\draw[->, bamberg3, line width=0.5mm] (i3) -- (k3);
			\draw[->, bamberg3, line width=0.5mm] (i3) -- (l3);
			\node[above=1mm of i3] {Outgoing 3-star};
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	Popularity ($\approx$ preferential attachment) and activity effects.
	
	\bigskip
	
	Do incoming or outgoing ties cluster together in nodes?
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{In-2-star}, \texttt{out-2-star}, and \texttt{out-3-star}.
\end{frame}

\begin{frame}
	\frametitle{Edge-wise shared partners and two-paths}
	\begin{columns}
		\column{0.2\textwidth}
		\[
		h_{\text{esp}} = \sum_{i, j, k} N_{ij} N_{jk} N_{ik}
		\]
		\begin{center}
			\begin{tikzpicture}[node distance=10mm and 6mm, 
				knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
				\node[knoten] (j1) {$j$};
				\node[knoten, below left=of j1] (i1) {$i$};
				\node[knoten, below right=of j1] (k1) {$k$};
				\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
				\draw[->, bamberg3, line width=0.5mm] (i1) -- (k1);
				\draw[->, bamberg3, line width=0.5mm] (j1) -- (k1);
			\end{tikzpicture}
		\end{center}
		\column{0.7\textwidth}
		\[
		h_{\text{twopath}} = \sum_{i \notin \{j; k\}} \sum_{j \notin \{i; k\}} \sum_{k \notin \{i; j\}} N_{ij} N_{jk} (1 - N_{ik}) (1 - N_{ki})
		\]
		\begin{center}
			\begin{tikzpicture}[node distance=10mm and 6mm, 
				knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
				\node[knoten] (j1) {$j$};
				\node[knoten, below left=of j1] (i1) {$i$};
				\node[knoten, below right=of j1] (k1) {$k$};
				\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
				\draw[->, bamberg3, line width=0.5mm] (j1) -- (k1);
			\end{tikzpicture}
		\end{center}
	\end{columns}
	
	\bigskip
	
	Are indirect paths also closed directly? E.\,g., due to efficiency, trust\ldots
	
	\bigskip
	
	Examples: ESP in information transmission. Two-paths in a recruitment network.
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{transitive triad} (T$_9$) and \texttt{2-path}.
\end{frame}

\begin{frame}
	\frametitle{Three-cycles}
	\[
	h_\text{three-cycle} = \sum_{i,j,k} N_{ij}N_{jk}N_{ki}
	\]
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 6mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (j1) {$j$};
			\node[knoten, below left=of j1] (i1) {$i$};
			\node[knoten, below right=of j1] (k1) {$k$};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
			\draw[->, bamberg3, line width=0.5mm] (j1) -- (k1);
			\draw[->, bamberg3, line width=0.5mm] (k1) -- (i1);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	Cyclical triads can often be found in friendship networks.
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{Cyclic Triad} (T$_{10}$).
\end{frame}

\begin{frame}
	\frametitle{Triad census \citep{holland1971transitivity}}
	\begin{center}
		\includegraphics[height=0.85\textheight]{spec_triadcensus}
	\end{center}
\end{frame}

\begin{frame}
	\frametitle{Four-cycles}
	\[
	h_\text{four-cycle} = \sum_{i,j,k,l} N_{ij}N_{jk}N_{kl}N_{li} (1-N_{ik}) (1-N_{jl}) (1-N_{ki}) (1-N_{lj})
	\]
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 10mm, 
			knoten/.style={inner sep=0pt, minimum size=6mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten] (j1) {$j$};
			\node[knoten, below=of j1] (i1) {$i$};
			\node[knoten, right=of j1] (k1) {$k$};
			\node[knoten, right=of i1] (l1) {$l$};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
			\draw[->, bamberg3, line width=0.5mm] (j1) -- (k1);
			\draw[->, bamberg3, line width=0.5mm] (k1) -- (l1);
			\draw[->, bamberg3, line width=0.5mm] (l1) -- (i1);
		\end{tikzpicture}
	\end{center}
	
	\bigskip
	
	Often found in networks with negative ties, for example international conflict, because it follows from structural balance.
	
	\bigskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{4-Cycle}.
\end{frame}

\begin{frame}
	\frametitle{Geometrically weighted edge-wise shared partners (GWESP)}
	\[
	h_\text{GWESP}(N, \alpha) = \text{e}^{\alpha} \sum_{i = 1}^{n - 2} \left\{ 1 - (1 - \text{e}^{-\alpha})^i \right\} \text{ESP}_i(N)
	\]
	\begin{center}
		where ESP$_i(N)$ is the number of edges with $i$ shared partners.
	\end{center}
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 10mm, 
			knoten/.style={inner sep=0pt, minimum size=4mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten, minimum size=6mm] (i1) at (0,0) {};
			\node[knoten, minimum size=6mm] (j1) at (0,2) {};
			\node[knoten] (k1) at (2,1) {};
			\node[knoten] (l1) at (4,1) {};
			\node[knoten] (m1) at (6,1) {};
			\node (n) at (7,1) {\textcolor{bamberg3}{\ldots}};
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (j1);
			\draw[->, bamberg3!25, line width=0.5mm] (i1) -- (m1);
			\draw[->, bamberg3!25, line width=0.5mm] (m1) -- (j1);
			\draw[->, bamberg3!50, line width=0.5mm] (i1) -- (l1);
			\draw[->, bamberg3!50, line width=0.5mm] (l1) -- (j1);
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (k1);
			\draw[->, bamberg3, line width=0.5mm] (k1) -- (j1);
		\end{tikzpicture}
	\end{center}
	
	\medskip
	
	Similar theoretical idea as transitive triads/edge-wise shared partners.
	
	\medskip
	
	Each additional shared partner is weighted less strongly.
	
	\medskip
	
	Avoids model degeneracy in exponential random graph models.
	
	\medskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{AT-T} (alternating triangle -- transitive).
\end{frame}

\begin{frame}
	\frametitle{Geometrically weighted non-edgewise shared partners (GWNSP)}
	\[
	h_\text{GWNSP}(N, \alpha) = \text{e}^{\alpha} \sum_{i = 1}^{n - 2} \left\{ 1 - (1 - \text{e}^{-\alpha})^i \right\} \text{NSP}_i(N)
	\]
	\begin{center}
		where NSP$_i(N)$ is the number of non-ties with $i$ shared partners.
	\end{center}
	\begin{center}
		\begin{tikzpicture}[node distance=10mm and 10mm, 
			knoten/.style={inner sep=0pt, minimum size=4mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten, minimum size=6mm] (i1) at (0,0) {};
			\node[knoten, minimum size=6mm] (j1) at (0,2) {};
			\node[knoten] (k1) at (2,1) {};
			\node[knoten] (l1) at (4,1) {};
			\node[knoten] (m1) at (6,1) {};
			\node (n) at (7,1) {\textcolor{bamberg3}{\ldots}};
			\draw[->, bamberg3!25, line width=0.5mm] (i1) -- (m1);
			\draw[->, bamberg3!25, line width=0.5mm] (m1) -- (j1);
			\draw[->, bamberg3!50, line width=0.5mm] (i1) -- (l1);
			\draw[->, bamberg3!50, line width=0.5mm] (l1) -- (j1);
			\draw[->, bamberg3, line width=0.5mm] (i1) -- (k1);
			\draw[->, bamberg3, line width=0.5mm] (k1) -- (j1);
		\end{tikzpicture}
	\end{center}
	
	\medskip
	
	Similar theoretical idea as two-paths.
	
	\medskip
	
	Each additional two-path is weighted less strongly.
	
	\medskip
	
	Avoids model degeneracy in exponential random graph models.
	
	\medskip
	
	Name of the network statistic in \texttt{PNet}: \texttt{A2P-T} (alternating 2-path -- transitive).
\end{frame}

\begin{frame}
	\frametitle{GWDegree or alternating $k$-star}
	\[
	h_\text{GWDegree}(N, \alpha) = \text{e}^{\alpha} \sum_{i = 1}^{n - 1} \left\{ 1 - (1 - \text{e}^{-\alpha})^i \right\} \text{D}_i(N)
	\]
	\begin{center}
		where D$_i(N)$ is the number of nodes with exactly $i$ ties.
		
		\begin{tikzpicture}[node distance=10mm and 10mm, 
			knoten/.style={inner sep=0pt, minimum size=4mm, circle, draw=bamberg3, line width=0.5mm, fill=bamberg4}]
			\node[knoten, minimum size=6mm] (i1) at (0,0) {};
			\node[knoten] (j1) at (1.5,1.5) {};
			\node[knoten] (k1) at (1.5,-1.5) {};
			\node[knoten] (l1) at (-1.5,-1.5) {};
			\node[knoten] (m1) at (-1.5,1.5) {};
			\draw[bamberg3, line width=0.5mm] (i1) -- (j1);
			\draw[bamberg3!50, line width=0.5mm] (i1) -- (k1);
			\draw[bamberg3!25, line width=0.5mm] (i1) -- (l1);
			\draw[bamberg3!13, line width=0.5mm] (i1) -- (m1);
		\end{tikzpicture}
	\end{center}
	
	\medskip
	
	Similar theoretical idea as stars (e.\,g., in-2-stars or out-2-stars) with weighting.
	
	\medskip
	
	Avoids model degeneracy in exponential random graph models.
	
	\medskip
	
	In \texttt{PNet}: \texttt{Alt-Star} (AS); \texttt{AinS} or \texttt{AoutS} for directed networks.
\end{frame}

\section{Theory building examples}

\begin{frame}
	\frametitle{ERGM theory building example 1}
	\framesubtitle{How can we model visits among inhabitants of a residential care home?}
	\begin{enumerate}
		\item \alert<2-3>{Dyadic covariates.}
		\only<3>{
			\begin{itemize}
				\item Age difference ($-$).
				\item Same gender ($+$).
				\item Proximity of apartments ($+$).
				\item Similar size of visible families ($+$).
				\item Similar profile of medical problems and disabilities ($+$).
				\item Apartment of alter is between ego's apartment and the restaurant ($+$).
			\end{itemize}
		}
		\item \alert<4-5>{Node covariates of ego.}
		\only<5>{
			\begin{itemize}
				\item Physical and mental fitness ($+$).
				\item Encouragement by family members ($+$).
				\item Owns a TV set ($-$).
			\end{itemize}
		}
		\item \alert<6-7>{Node covariates of alter.}
		\only<7>{
			\begin{itemize}
				\item Spacious balcony ($+$).
				\item Pension level ($+$).
				\item Altruism ($+$).
				\item Physical and mental fitness ($+$).
				\item Apartment is close to the restaurant ($+$).
			\end{itemize}
		}
		\item \alert<8-9>{Endogenous graph statistics.}
		\only<9>{
			\begin{itemize}
				\item Reciprocity.
				\item Edge-wise shared partners.
				\item Cyclic triads.
				\item $k$-in-stars.
				\item $k$-out-stars.
			\end{itemize}
		}
	\end{enumerate}
\end{frame}

\begin{frame}
	\frametitle{ERGM theory-building example 2}
	\framesubtitle{How can we explain militarised interstate disputes?}
	\begin{enumerate}
		\item \alert<2-3>{Dyadic covariates.}
		\only<3>{
			\begin{itemize}
				\item Direct contiguity ($+$).
				\item Colonial contiguity ($-$).
				\item Distance ($-$).
				\item Both countries are democracies ($-$).
				\item Military capability ratio ($-$).
				\item Trade dependence ($-$).
				\item Bilateral alliances ($-$).
				\item Joint membership in international organizations ($-$).
				\item Shared allies ($-$).
			\end{itemize}
		}
		\item \alert<4-5>{Node covariates of ego.}
		\only<5>{
			\begin{itemize}
				\item Democracy? No\ldots
				\item GDP per capita? No\ldots
				\item Demography; share of young men? Maybe\ldots
			\end{itemize}
		}
		\item \alert<6-7>{Node covariates of alter.}
		\only<7>{
			\begin{itemize}
				\item Democracy ($-$).
				\item GDP per capita ($-$).
				\item Natural resources?
				\item Has nuclear arms ($-$).
			\end{itemize}
		}
		\item \alert<8-9>{Endogenous graph statistics.}
		\only<9>{
			\begin{itemize}
				\item Reciprocity ($+$).
				\item Structural balance: closed triangles ($-$).
				\item Structural balance: 4-cycles ($+$).
				\item Structural balance: edge-wise shared partners ($-$).
				\item $k$-in-stars ($+$).
				\item $k$-out-stars ($+$).
			\end{itemize}
		}
	\end{enumerate}
\end{frame}

\section{A case study in \texttt{R} using \texttt{statnet}: information exchange in policy networks}

\begin{frame}
	\frametitle{Case study: Toxic chemicals regulation policy network}
	\framesubtitle{\citep{leifeld2012information}}
	\begin{columns}
		\column{0.65\textwidth}
		\begin{itemize}
			\item How does information exchange in a policy domain work?
			\item Theory: Actors have limited resources and try to establish low-cost contacts.
			\item Transaction cost theory of politics.
			\item They do so by\ldots
			\begin{itemize}
				\item using committees for cheap networking,
				\item reciprocating existing ties, and
				\item relying on third-party quality checks.
			\end{itemize}
			\item Scientific/technical versus political/strategic information exchange.
		\end{itemize}
		\column{0.35\textwidth}
		\includegraphics[width=0.9\textwidth]{spec_chemicals}
	\end{columns}
\end{frame}

\begin{frame}
	\frametitle{ERGM results}
	\begin{tabular}{l D{(}{(}{7} D{(}{(}{7}}
		\toprule
		& \multicolumn{1}{c}{Political inf.ex.}         & \multicolumn{1}{c}{Technical inf.ex.}\\
		\cmidrule(lr){2-2}                              \cmidrule(lr){3-3}
		Edges                                   & -3.63 \; (0.19)^{***}                         & -5.86 \; (0.31)^{***}\\
		Preference similarity                   & 0.07 \; (0.07)                                & -0.05 \; (0.11)\\
		Interest group homophily                & 1.18 \; (0.12)^{***}                          & 1.01 \; (0.32)^{**}\\
		Governmental alter                      & 0.53 \; (0.06)^{***}                          & 0.41 \; (0.07)^{***}\\
		Scientific ego                          & 0.05 \; (0.09)                                & 1.51 \; (0.10)^{***}\\
		Common committees                       & 0.31 \; (0.01)^{***}                          & 0.16 \; (0.01)^{***}\\
		Scientific communication                & 3.12 \; (0.38)^{***}                          &  \\
		Political communication                 &                                               & 2.75 \; (0.06)^{***}\\
		Influence attribution                   & 0.84 \; (0.07)^{***}                          & 0.47 \; (0.07)^{***}\\
		GWESP: edge-wise shared p.              & 1.26 \; (0.03)^{***}                          & 0.43 \; (0.04)^{***}\\
		GWDSP: dyadic shared p.                 & -0.15 \; (0.02)^{***}                         & -0.23 \; (0.02)^{***}\\
		Reciprocity                             & 0.82 \; (0.06)^{***}                          & 1.86 \; (0.15)^{***}\\
		\bottomrule
	\end{tabular}
\end{frame}

\begin{frame}[fragile]{Data preparation for ERGM analysis in \texttt{R}}
<<ajps-ergm-chemnet, size = "footnotesize", message = FALSE>>=
library("sna")
library("ergm")
seed <- 12345
data("chemnet", package = "btergm")

sci <- scito * t(scifrom)  # create confirmed network relation
prefsim <- dist(intpos, method = "euclidean")  # Euclidean distances over preferences
prefsim <- max(prefsim) - prefsim  # convert distances to similarities
prefsim <- as.matrix(prefsim) # from dist to matrix object
committee <- committee %*% t(committee)  # co-memberships in committees
diag(committee) <- 0 # the diagonal has no meaning
types <- types[, 1]  # convert actor types to vector

nw.pol <- network(pol) # political/stratgic information exchange
set.vertex.attribute(nw.pol, "orgtype", types)
set.vertex.attribute(nw.pol, "betweenness", betweenness(nw.pol)) # centrality
nw.sci <- network(sci) # technical/scientific information exchange
set.vertex.attribute(nw.sci, "orgtype", types)
set.vertex.attribute(nw.sci, "betweenness", betweenness(nw.sci)) # centrality
@
\end{frame}

\begin{frame}[fragile]{ERGM specification using \texttt{statnet}}
\vspace{-5mm}
\begin{columns}
\column[t]{0.47\textwidth}
<<ajps-ergm-spec-pol, size = "footnotesize", message = FALSE, warning = FALSE>>=
pol_fit <- ergm(nw.pol ~
    edges +
    edgecov(prefsim) +
    mutual +
    nodemix("orgtype", base = -7) +
    nodeifactor("orgtype", base = -1) +
    nodeofactor("orgtype", base = -5) +
    edgecov(committee) +
    edgecov(nw.sci) +
    edgecov(infrep) +
    gwesp(0.1, fixed = TRUE) +
    gwdsp(0.1, fixed = TRUE),
    control = control.ergm(seed = seed)
)
@
\column[t]{0.47\textwidth}
<<ajps-ergm-spec-sci, size = "footnotesize", message = FALSE, warning = FALSE>>=
sci_fit <- ergm(nw.sci ~
    edges +
    edgecov(prefsim) +
    mutual +
    nodemix("orgtype", base = -7) +
    nodeifactor("orgtype", base = -1) +
    nodeofactor("orgtype", base = -5) +
    edgecov(committee) +
    edgecov(nw.pol) +
    edgecov(infrep) +
    gwesp(0.1, fixed = TRUE) +
    gwdsp(0.1, fixed = TRUE),
    control = control.ergm(seed = seed)
)
@
\end{columns}

\bigskip

For a full overview of model terms for the \texttt{ergm} function:
<<ergm-model-terms-help, size = "footnotesize", eval = FALSE>>=
?"ergm-terms"
@
Also look at the 2008 special issue on \texttt{statnet} in the \emph{Journal of Statistical Software}.
\end{frame}

\begin{frame}[fragile]{ERGM model output}
<<ergm-ajps-output-pol, size = "tiny">>=
summary(pol_fit)
@
\end{frame}

\begin{frame}[fragile]{ERGM model output}
<<ergm-ajps-output-texreg, size = "tiny", message = FALSE>>=
library("texreg")
screenreg(list(pol_fit, sci_fit), single.row = TRUE, custom.model.names = c("POL", "SCI"))
@
\end{frame}

