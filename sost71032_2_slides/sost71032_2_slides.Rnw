\section{Case study: reputation formation in policy networks}

\begin{frame}
	\frametitle{Case study: Reputation formation in policy networks}
	\framesubtitle{\citep{ingold2016structural}}
	\begin{itemize}
		\item Four policy networks.
		\item Different time, country, stage of the policy cycle, level.
		\item Climate, chemicals, flood prevention, telecommunications.
		\item Previous research: influence reputation = proxy for influence.
		\item Research question: how do political actors become influential in the first place?
		\item ERGM framework: Why does $i$ rate $j$ as influential?
		\item Theory: two components matter:
		\begin{enumerate}
			\item institutional power (formal authority, committee memberships)
			\item structural power (cooperation, visibility, control of information)
		\end{enumerate}
		\item All these data have been collected through interviews.
	\end{itemize}
\end{frame}

