\begin{frame}
	\frametitle{Network types}
	\begin{center}
		\includegraphics[width=0.5\textwidth]{network_types.pdf}
		\tiny{\citep{leifeld2020netzwerkanalyse}}
	\end{center}
\end{frame}

\begin{frame}[fragile]{Network representation in \texttt{statnet}}
<<statnet-network-data, size = "footnotesize", message = FALSE, warning = FALSE, results = "hide">>=
library("statnet") # also loads the network, sna, and ergm packages
data("knecht", package = "btergm") # school class friendship networks
@
<<statnet-network-matrix, size = "footnotesize">>=
class(friendship)
length(friendship)
dim(friendship[[1]])
table(friendship[[1]])
isSymmetric(friendship[[1]])
@
\end{frame}

\begin{frame}[fragile]{Network representation in \texttt{statnet}}
<<statnet-network-object, size = "footnotesize", message = FALSE, warning = FALSE>>=
fr1 <- network(friendship[[1]], directed = TRUE) # create directed network object
head(demographics)
dim(demographics)
set.vertex.attribute(fr1, "ethnicity", demographics$ethnicity) # add node attribute
set.vertex.attribute(fr1, "sex", demographics$sex) # add node attribute
list.vertex.attributes(fr1) # list all node attributes saved in the network object
get.vertex.attribute(fr1, "sex") # get the node attribute back from the network object
@
\end{frame}

\begin{frame}[fragile]{Network representation in \texttt{statnet}}
<<statnet-network-print, size = "footnotesize", message = FALSE, warning = FALSE>>=
fr1 # summarise the network object
@
\end{frame}

\begin{frame}[fragile]{Network representation in \texttt{statnet}}
<<statnet-network-plot, size = "scriptsize", dev = 'pdf', crop = TRUE, out.width = "47%", fig.width = 8, fig.height = 8>>=
plot(fr1, displaylabels = TRUE, vertex.col = "sex", vertex.cex = 2, edge.col = "darkgray")
@
\end{frame}

\begin{frame}
	\frametitle{How to enter your network data into the software}
	\begin{itemize}
		\item adjacency matrix
		\item edge list: \texttt{source vertex -- target -- edge weight}
		\item node list: \texttt{source vertex -- target 1 -- target 2} etc.
	\end{itemize}
	
	\bigskip
	
	Matrices are error-prone. \\ Edge and node lists require scripting skills.
\end{frame}

\begin{frame}[fragile]{How to enter data as an edgelist and convert into a matrix}
<<statnet-edgelist-enter, size = "footnotesize">>=
mydata <- matrix(c(
		"Thomas", "Martin",
		"Franz", "Martin",
		"Martin", "Franz",
		"Anna", "Thomas"
), ncol = 2, byrow = TRUE)
mydata

nodes <- unique(c(mydata[, 1], mydata[, 2]))
nodes

mat <- matrix(0, nrow = length(nodes), ncol = length(nodes))
rownames(mat) <- colnames(mat) <- nodes
@
\end{frame}

\begin{frame}[fragile]{How to enter data as an edgelist and convert into a matrix}
<<statnet-edgelist-convert, size = "footnotesize", message = FALSE>>=
for (i in 1:nrow(mydata)) {
    row.index <- which(nodes == mydata[i, 1])
    col.index <- which(nodes == mydata[i, 2])
    mat[row.index, col.index] <- 1
}
mat

as.matrix(network(mydata)) # or via network object
@
\end{frame}

