\begin{frame}
	\frametitle{Dyad, triad, cycle, star}
	\begin{columns}[b]
		\column{0.48\textwidth}
		\begin{itemize}
		  \item We can count sub-structures.
			\item A \alert{dyad} is any pair of two vertices.
			\item A \alert{tie} or \alert{edge} is an adjacent pair of vertices, e.\,g., 3--10 or 6--7.
			\item A \alert{triad} or \alert{triangle} is a completely connected subgraph of three vertices (1--5--11).
			\item A \alert{cycle} is a closed path, e.\,g., 6--5--9--7.
		\end{itemize}
		\column{0.45\textwidth}
		\includegraphics[width=1.0\textwidth]{walk.pdf}
	\end{columns}
	\begin{itemize}
		\item In a \alert{star}, a vertex is connected to all other vertices, but they are not connected with each other (e.\,g., 1--2--3--6--10)
		\item A \alert{loop} is an edge where the source vertex and the target vertex are identical. This corresponds to a diagonal cell entry in a matrix (e.\,g., 1).
	\end{itemize}
\end{frame}

\begin{frame}{Mechanisms, configurations, and models}
	\alert{Mechanisms} are causal processes that form networks, for example preferential attachment, homophily, social influence/contagion, brokerage, structural balance, the norm of reciprocity etc. They are at the theoretical level.
	
	\bigskip
	
	\alert{Configurations} are measurable quantities in networks. Sometimes called ``motifs'', ``ensembles'', ``subgraph counts'', or ``network statistics''.
	
	\smallskip
	
	For example, density, reciprocity, counts of balanced or unbalanced triads, degree distribution, two-stars, etc.
	
	\smallskip
	
	They are at the conceptual level and operationalise theoretical mechanisms. They are countable, given network data.
	
	\bigskip
	
	In network \alert{models}, we usually plug multiple configurations together to test theories of how networks form. For example, exponential random graph models (ERGM), stochastic actor-oriented models (SAOM), relational event models (REM) etc.
\end{frame}

\section{Dependence between observations}

\begin{frame}{Statistical modelling of networks}
  \alert{Goal: explain who is connected to whom}.
  \begin{itemize}
    \item Based on network \alert{mechanisms} (preferential attachment, structural balance, homophily, etc).
    \item Based on other \alert{relations} between the same nodes.
    \item Based on \alert{attributes} of the sender or receiver nodes.
  \end{itemize}
  
  \bigskip
  
  The goal is \alert{inference}: we want to build a model about the superpopulation -- i.\,e., if we were to collect another network dataset of the same underlying process, the estimated coefficients should represent the network well.
  
  \bigskip
  
  Statistical models are \alert{probabilistic}: we want to assess the uncertainty around the estimated coefficients.
  
  \bigskip
  
  Sometimes, we also want to \alert{explain how networks change over time}.
  
  \bigskip
  
  And sometimes, we want to \alert{explain why nodes in a network have specific attributes}.
\end{frame}

\begin{frame}{Overview of statistical network models and techniques}
	\begin{itemize}
		\item Exponential Random Graph Model (ERGM). \hfill \quad \alert{$\leftarrow$ lectures 2--3}
		\begin{itemize}
			\item[] Extensions: Temporal, Generalized, Count, Multilayer, Multilevel \hfill  {\normalsize \quad \alert{$\leftarrow$ lecture 4}}
		\end{itemize}
		\item Stochastic Actor-Oriented Model (SAOM). \hfill \quad \alert{$\leftarrow$ lecture 4}
		\item Relational Event Model (REM). \hfill \quad \alert{$\leftarrow$ lecture 5}
		\item Latent Space Models (LSM). \hfill \quad \alert{$\leftarrow$ lecture 6}
		\item Additive and Multiplicative Effects Network Models (AMEN). \hfill \quad \alert{$\leftarrow$ lecture 6}
		\item Conditional Uniform Graph  (CUG) Tests. \hfill \quad \alert{$\leftarrow$ lecture 6}
		\item Quadratic Assignment Procedure (QAP). \hfill \quad \alert{$\leftarrow$ lecture 6}
		\item Latent Order Logistic Model (LOLOG).
		\item Network Autocorrelation Model (NAM).
		\item Auto-Logistic Actor Attribute Model (ALAAM).
		\item Exponential Random Network Model (ERNM).
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{Non-independence of observations}
	Assumption in regression models: observations are independent and identically distributed (i.i.d.).
	
	\bigskip
	
	$P(Y) = P(y_1, y_2, \ldots, y_n) = P(y_1) \cdot P(y_2) \cdot \ldots \cdot P(y_n)$
	
	\only<2>{\bigskip}
	
	\only<2>{$P(Y \mid X) = P(y_1 \mid \mathbf{x}_1) \cdot P(y_2 \mid \mathbf{x}_2) \cdot \ldots \cdot P(y_n \mid \mathbf{x}_n)$}
	
	\bigskip
	
	If an increase in any $y_i$ were causing a change in any $y_j$, multiplication of $P(y_i)$ and $P(y_j)$ would lead to a biased joint probability $P(Y)$.
\end{frame}

\begin{frame}
	\frametitle{Non-independence of observations}
	\begin{itemize}
		\item Reconsider this in terms of the likelihood of a model given the data:
		\[
		L (\boldsymbol{\theta} | \bm{y}, \bm{X}) = \prod_{i=1}^{n} f ( y_i | \bm{x}_i, \boldsymbol{\theta})
		\]
		\item The product implies that one probability does not influence the other.
		\item Two observations have the same $\hat{y}_i$ if they match on covariates.
		\item This match cannot be established if one influences the other.
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{What happens if we ignore this?}
	\begin{itemize}
		\item We can still apply a regression model, i.\,e., compute the likelihood by taking the product.
		\item However, the aggregated likelihood will be wrong.
		\item This will falsely attribute explanatory power to covariates.
		\item Estimates and uncertainty measures (standard errors, $p$ values) are biased.
		\item We can neither conclude that a covariate effect is really there, nor that the model fits the data adequately.
		\item We risk faulty inferences.
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{The problem of data multiplication}
	\begin{itemize}
		\item Undirected network: $\genfrac(){0pt}{}{n}{2}$ edges.
		\item Directed network: $2{\genfrac(){0pt}{}{n}{2}}$ edges.
		\item With $n = 100$ actors, this amounts to 9,900 directed edges!
		\item Problem: each observation is counted several times (e.\,g., 9,900 edges although there are only 100 actors who are causing the observations).
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{The problem of data multiplication}
	\begin{block}{Perspective 1: \alert{$p$ value shrinkage}}
		\begin{itemize}
			\item With increasing $N$, uncertainty $p$ decreases.
			\item In dyadic regression analysis, we would thus be overconfident in the results.
		\end{itemize}
	\end{block}
	\begin{block}{Perspective 2: \alert{multiparty events}}
		(cf.\ Cranmer, Leifeld, McClurg, and Rolfe 2017)
		\begin{itemize}
			\item WW\,I and WW\,II account for 46.14\% of all wars since 1816.
			\item 53.44\% of the wars in the 20th century.
			\item Were WWI and WWII really 567 entirely independent dyadic wars?
			\item Was Britain's declaration of war on Germany really completely independent of Germany's invasion of Poland?
		\end{itemize}
	\end{block}
\end{frame}

\begin{frame}
	\frametitle{Unmodelled dependencies as omitted variable bias}
	If we don't model an important causal factor, a regression model may suffer from omitted variable bias.\\
	\bigskip
	$Y = \alpha + \beta_1 X_1 + \beta_2 X_2 + \epsilon$\\
	\bigskip
	Example: If an omitted variable $X_3$ is correlated both with $Y$ and $X_2$, too much variance in $Y$ is explained by $X_2$, leading to a biased estimate $\beta_2$.\\
	\bigskip
	If we do not model all dependencies, the same result holds!\\
	\bigskip
	That leaves us with the task of specifying the dependencies correctly!
\end{frame}

\begin{frame}
	\frametitle{Unmodelled dependencies as omitted variable bias}
	\begin{block}{Omitted variable bias in a GLM}
		\begin{itemize}
			\item $Y$: grades
			\item $X_1$: attendance
			\item $X_2$: intelligence/skills
			\item $X_3$: study
		\end{itemize}
		If $X_3$ is omitted, grades are wrongly attributed to attendance.
	\end{block}
	\begin{block}{Omitted variable bias in a network context}
		\begin{itemize}
			\item $Y$: friendship
			\item $X_1$: similar interests
			\item $X_2$: individual attractiveness
			\item $X_3$: network dependence: triadic closure, $k$-stars, reciprocity
		\end{itemize}
		If $X_3$ is omitted, $\beta_1$ and $\beta_2$ are potentially biased.
	\end{block}
\end{frame}

\begin{frame}
	\frametitle{Modelling dependencies correctly}
	\begin{itemize}
		\item Dependencies often entail more than two nodes.
		\item Switch from dyad to network level as the observation.
		\item Which collection of network statistics \emph{and} exogenous covariates makes the structure of the network most likely?
		\item Specification of dependencies with two or more nodes.
		\item This is the basic idea of ERGMs!
		\item But first, we need to discuss permutation tests today.
	\end{itemize}
\end{frame}

\begin{frame}
	\frametitle{The aggregation problem in the social sciences}
	Morris, Martina (2004): Book Review of Duncan Watts, Six Degrees: The Science of a Connected Age. \href{http://www.cmu.edu/joss/content/reviews/Morris/}{\emph{Journal of Social Structure} 5}:
	
	\bigskip
	
	\begin{quote}
		``The true heart of the social sciences: the aggregation problem. Without the aggregation problem, there is only psychology. The problem of creating a whole from some irreducible function of the parts---a social fact---is the raison d'être of social science.''
	\end{quote}
	
	\medskip
	
	\begin{quote}
		[Alan Barton of the Bureau of Applied Social Research suggested back in the 1950s that] ``\alert{survey research was the equivalent of grinding meat into hamburger, then trying to reconstruct the cow}.''
	\end{quote}
	
	\medskip
	
	\includegraphics[height=2cm]{dep_beef_grind} \includegraphics[height=2cm]{dep_beef_patty} \includegraphics[height=2cm]{dep_beef_hamburger} \includegraphics[height=2cm]{dep_beef_cogs} \includegraphics[height=2cm]{dep_beef_organs}
\end{frame}

\section{Network data}

\frame{\frametitle{Elements of networks}
	\begin{columns}
		\column{0.5\textwidth}
		\includegraphics[width=0.9\textwidth]{network_onemode.pdf}
		\column{0.6\textwidth}
		\begin{block}{A network $N$ consists of\ldots}
			\begin{itemize}
				\item \alert{vertices} (\textit{nodes}, \textit{points})
				\item denoted as $i, j, k$
				\item \alert{edges} (\textit{ties}, \textit{lines})
				\item denoted as $N_{ij}, N_{ik}$ etc.
			\end{itemize}
		\end{block}
		\vspace{0.5cm}
		\begin{block}{A network\ldots}
			\begin{itemize}
				\item is a descriptive model of social reality.
				\item depicts relations rather than attributes.
				\item often represents the outcome of a dynamic process.
			\end{itemize}
		\end{block}
	\end{columns}
}

\begin{frame}
	\frametitle{Two-mode networks}
	\begin{columns}
		\column{0.5\textwidth}
		\includegraphics[width=0.9\textwidth]{network_twomode.pdf}
		\column{0.5\textwidth}
		\begin{block}{Two-mode networks:}
			\begin{itemize}
				\item a.k.a.\ bipartite graphs
				\item a.k.a.\ affiliation networks
				\item two classes of nodes
				\item no within-class edges
			\end{itemize}
		\end{block}
		\vspace{0.5cm}
		\begin{block}{Examples}
			\begin{itemize}
				\item employees and departments
				\item organizations and associations
				\item managers and boards of directors
			\end{itemize}
		\end{block}
	\end{columns}
\end{frame}

