\section{TERGM specification}

\begin{frame}
	\frametitle{Exogenous covariate: constant or time-varying}
	\[
	h_\text{time-constant covariate} (N^{t},X) = \sum_{i \neq j} N^{t}_{ij} X_{ij}
	\]

	\bigskip

	\centering or

	\bigskip

	\[
	h_\text{time-varying covariate} (N^{t},X^{t}) = \sum_{i \neq j} N^{t}_{ij} X^{t}_{ij}
	\]

	\bigskip

	\centering (where $X$ is a relational matrix of the same dimensions as $N$)
\end{frame}

\begin{frame}
	\frametitle{Autoregression and dyadic stability}
	\[
	h_\text{positive autoregression} = \sum_{i \neq j} N_{ij}^{t}N_{ij}^{t-1}
	\]

	\bigskip

	\[
	h_\text{dyadic stability} = \sum_{i \neq j} N_{ij}^{t} N_{ij}^{t-1} + (1- N_{ij}^{t}) (1-N_{ij}^{t-1})
	\]

	\bigskip

	\[
	h_\text{edge innovation} = \sum_{ij} N_{ij}^{t} (1 - N_{ij}^{t-1})
	\]

	\bigskip

	\[
	h_\text{edge loss}= \sum_{ij} (1- N_{ij}^{t})N_{ij}^{t-1}
	\]
\end{frame}

\begin{frame}
	\frametitle{Single-period delayed reciprocity}
	\[
	h_\text{delayed reciprocity}(N^{t}, N^{t-1}) = \sum_{ji} N^{t}_{ij}N^{t-1}_{ji}
	\]

	\vspace{1cm}
	More complex temporal dependencies over more than two time steps are possible. Example: Triadic closure over three time periods.
\end{frame}

\begin{frame}
 \frametitle{Time trends and time--covariate interactions}
 \[
  h_\text{time-trend} (t, a, b, f) = f(t) \cdot [t \geq a] \times [t \leq b]
 \]
  or
 \[
  h_\text{timecov} (N^t, X^t, t, a, b, f) = N^t_{ij} \times X^t_{ij} \times f(t) \times [t \geq a] \times [t \leq b]
 \]

 where\ldots
 \begin{itemize}
  \item $t$ is the current time point,
  \item $a$ is the minimum cut-off value,
  \item $b$ is the maximum cut-off value, and
  \item $f(\cdot)$ is an arbitrary function, such as: constant: \\
  $f(t) = 1$; \quad linear: $f(t) = t$; \quad squared: $f(t) = t^2$.
 \end{itemize}
 We can combine multiple time trends in the specification, such as $\theta_1 t + \theta_2 t^2$, for temporally concave or convex intercepts.

 \medskip

 Drop the intercept when including time trends that encompass all time points!
\end{frame}

\section{Composition change}

\begin{frame}
 \frametitle{Composition change}
 \begin{itemize}
  \item Composition change is not an issue for estimation; just provide matrices with different dimensions.
  \item If node labels are included in the data, the software will adjust the dimensions automatically.
 \end{itemize}
 \begin{center}
 \begin{tikzpicture}
  \node[rectangle, draw] (n1) at (0, 0) {$N^1$: 25};
  \node[rectangle, draw] (n2) at (2, 0) {$N^2$: \only<1-2>{30}\only<3>{\textbf{\alert{30}}}};
  \node[rectangle, draw] (n3) at (4, 0) {$N^3$: 27};
  \node[rectangle, draw] (n4) at (6, 0) {$N^4$: 14};

  \node<2->[rectangle, draw, gray] (n1b) at (2, -1) {$N^1$: 25};
  \node<2->[rectangle, draw, gray] (n2b) at (4, -1) {$N^2$: \only<1-2>{30}\only<3>{\textbf{\alert{30}}}};
  \node<2->[rectangle, draw, gray] (n3b) at (6, -1) {$N^3$: \only<1-2>{27}\only<3>{\textbf{\alert{27}}}};

  \draw<2->[line width = 1pt, ->, gray] (n1b.40) -- (n2.320);
  \draw<2->[line width = 1pt, ->, gray] (n2b.40) -- (n3.320);
  \draw<2->[line width = 1pt, ->, gray] (n3b.40) -- (n4.320);
 \end{tikzpicture}
 \end{center}
 \begin{itemize}
  \item Imbalance in node numbers means some time points may influence the coefficients more heavily than others.
 \end{itemize}
\end{frame}

