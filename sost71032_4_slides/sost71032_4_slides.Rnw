\section{Temporal exponential random graph model (TERGM)}

\begin{frame}{ERGM extension: The Temporal ERGM}{\citep{leifeld2018temporal}}
	Every network $N^t$ \emph{may} depend on $K \in \{0,1,\hdots, T - 1\}$ previous (lagged) networks.

	\bigskip

	Probability of observing $N^t$:
	\[
	P(N^{t} \mid N^{t - K}, \ldots, N^{t - 1}, \boldsymbol{\theta}) = \frac{\exp(\boldsymbol{\theta}^\top \alert<2>{\mathbf{h}(N^{t}, N^{t - 1}, \ldots, N^{t - K})})}{c(\boldsymbol{\theta}, N^{t - K}, \ldots, N^{t - 1})}
	\]

	Assumption: $K$ fully encompasses the dependencies of $N^{t}$. %Networks in the time series occurring prior to $N^{t-K}$ are independent of $N^{t}$.

	\bigskip

	\alert<2>{Configurations can be computed over current and past networks.}
\end{frame}

\begin{frame}
	\frametitle{The TERGM}
	Probability of observing the whole sequence of networks:
	\[
	P(N^{K + 1},\ldots, N^{T} \mid N^{1}, \ldots,N^{K}, \boldsymbol{\theta}) = \prod_{t = K + 1}^{T} P(N^{t} \mid N^{t - K}, \ldots, N^{t - 1}, \boldsymbol{\theta})
	\]

	\bigskip

	Illustration with $T = 8$ and $K = 2$:

	\bigskip

	\begin{tikzpicture}
		\usetikzlibrary{shapes.misc}
